{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegisflux.local/schemas/visibility/dns-observed.schema.json",
  "title": "Aegis DNS Observed",
  "allOf": [
    {
      "$ref": "common-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "const": "aegis.dns.observed"
        },
        "payload": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1
            },
            "query_type": {
              "type": ["string", "null"]
            },
            "answers": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "resolver": {
              "type": ["string", "null"]
            },
            "process_guid": {
              "type": ["string", "null"]
            },
            "pid": {
              "type": ["integer", "null"],
              "minimum": 0
            },
            "correlation_method": {
              "type": "string",
              "minLength": 1
            },
            "correlation_confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          },
          "required": ["query", "answers", "correlation_method", "correlation_confidence"],
          "additionalProperties": false
        }
      }
    }
  ]
}
