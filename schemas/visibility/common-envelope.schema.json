{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegisflux.local/schemas/visibility/common-envelope.schema.json",
  "title": "Aegis Visibility Event Envelope",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "visibility.v1"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_ms": {
      "type": "integer",
      "minimum": 0
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "device_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "sensor_version": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "payload": {
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "timestamp_ms",
    "source",
    "device_id",
    "agent_id",
    "sensor_version",
    "sequence",
    "payload"
  ],
  "additionalProperties": false
}
