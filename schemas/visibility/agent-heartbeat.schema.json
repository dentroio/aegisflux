{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegisflux.local/schemas/visibility/agent-heartbeat.schema.json",
  "title": "Aegis Agent Heartbeat",
  "allOf": [
    {
      "$ref": "common-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "event_type": {
          "const": "aegis.agent.heartbeat"
        },
        "payload": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["starting", "healthy", "degraded", "stopping", "error"]
            },
            "message": {
              "type": "string"
            },
            "os": {
              "type": "string",
              "minLength": 1
            },
            "arch": {
              "type": "string",
              "minLength": 1
            },
            "capabilities": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            }
          },
          "required": ["status", "message", "os", "arch"],
          "additionalProperties": false
        }
      }
    }
  ]
}
