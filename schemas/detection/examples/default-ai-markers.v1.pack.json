  "min_agent_version": "0.1.0",
  "supported_os": ["windows", "linux"],
  "mode": "observe",
  "expires_at": null,
  "rollback_pack_version": null,
  "signature": {
    "algorithm": "ed25519",
    "key_id": "fixture-lab-2026-05",
    "value_b64": "acfQaNWxmfEclng/se9xp7ZJ+sYJR+53u7J+Qj3FEZKn4r601+AwkMx3v6VoGMahgP5vSAc2Ht8ZH8wIxzXNSA=="
  },
  "evaluator_limits": {
    "max_wall_time_ms_per_batch": 50,
    "max_heap_bytes": 2097152,
    "max_rules_evaluated_per_batch": 256,
    "max_cpu_percent_soft": 5,
