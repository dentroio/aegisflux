{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegisflux.local/schemas/detection/detection-pack.v1.schema.json",
  "title": "Aegis Detection Pack",
  "description": "Versioned, signed, observe-only detection intelligence for endpoint agents. Data-only matchers; no scripts or executable payloads.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "detection_pack.v1"
    },
    "pack_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "pack_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Semantic version of this pack artifact.",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC3339 timestamp when the pack was authored."
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "Provenance label (build pipeline id, research item, tenant feed, etc.)."
    },
    "min_agent_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Minimum agent / sensor semver that understands this pack revision."
    },
    "supported_os": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["windows", "linux", "macos"]
      }
    },
    "mode": {
      "type": "string",
      "const": "observe",
      "description": "v1 packs are observe-only. Enforcement modes are reserved for future schema versions."
    },
    "expires_at": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "string",
          "format": "date-time",
          "description": "Optional RFC3339 expiry. Agents should stop evaluating expired packs."
        }
      ]
    },
    "rollback_pack_version": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "description": "Optional last-known-good pack_version to revert to if this artifact fails validation at runtime."
        }
      ]
    },
    "signature": {
      "$ref": "#/$defs/packSignature"
    },
    "evaluator_limits": {
      "$ref": "#/$defs/evaluatorLimits"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "$ref": "#/$defs/detectionRule"
      }
    },
    "references": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "string",
        "format": "uri",
        "maxLength": 2048
      }
    }
  },
  "required": [
    "schema_version",
    "pack_id",
    "pack_version",
    "created_at",
    "min_agent_version",
    "supported_os",
    "mode",
    "signature",
    "evaluator_limits",
    "rules"
  ],
  "allOf": [
    {
      "anyOf": [
        { "required": ["author"] },
        { "required": ["source"] }
      ]
    }
  ],
  "$defs": {
    "packSignature": {
      "type": "object",
      "additionalProperties": false,
      "description": "Detached signature over the canonical pack bytes (see evaluator contract).",
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["ed25519", "rs256"]
        },
        "key_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "value_b64": {
          "type": "string",
          "minLength": 1,
          "maxLength": 8192,
          "pattern": "^[A-Za-z0-9+/]+=*$",
          "description": "Base64-encoded signature bytes."
        }
      },
      "required": ["algorithm", "key_id", "value_b64"]
    },
    "evaluatorLimits": {
      "type": "object",
      "additionalProperties": false,
      "description": "Upper bounds agents must enforce (or stricter) while evaluating this pack.",
      "properties": {
        "max_wall_time_ms_per_batch": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60000
        },
        "max_heap_bytes": {
          "type": "integer",
          "minimum": 65536,
          "maximum": 268435456
        },
        "max_rules_evaluated_per_batch": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10000
        },
        "max_cpu_percent_soft": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Soft cap; agents may yield when sustained CPU exceeds this percentage."
        },
        "max_string_comparisons_per_rule": {
          "type": "integer",
          "minimum": 16,
          "maximum": 1048576
        },
        "max_clause_depth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "description": "Maximum nesting depth for composite match clauses."
        },
        "max_clauses_per_rule": {
          "type": "integer",
          "minimum": 1,
          "maximum": 256
        }
      },
      "required": [
        "max_wall_time_ms_per_batch",
        "max_heap_bytes",
        "max_rules_evaluated_per_batch",
        "max_cpu_percent_soft",
        "max_string_comparisons_per_rule",
        "max_clause_depth",
        "max_clauses_per_rule"
      ]
    },
    "detectionRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rule_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "target_os": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["windows", "linux", "macos"]
          },
          "description": "If set, the rule is evaluated only on these OS values (subset of pack supported_os)."
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096
        },
        "classification": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "pattern_tags": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "agent_likelihood": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "risk_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "recommended_action": {
          "type": "string",
          "enum": ["monitor", "review", "policy_candidate"]
        },
        "false_positive_notes": {
          "type": "string",
          "maxLength": 8192
        },
        "required_evidence": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "process",
              "command_line",
              "process_path",
              "parent_process",
              "dns_query",
              "dns_answer",
              "network_flow",
              "browser_process",
              "browser_extension",
              "sase_component"
            ]
          },
          "description": "Evidence kinds the evaluator should attach when this rule matches."
        },
        "match": {
          "$ref": "#/$defs/clause"
        },
        "references": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "string",
            "format": "uri",
            "maxLength": 2048
          }
        }
      },
      "required": [
        "rule_id",
        "priority",
        "title",
        "description",
        "classification",
        "pattern_tags",
        "agent_likelihood",
        "confidence",
        "risk_score",
        "recommended_action",
        "required_evidence",
        "match"
      ]
    },
    "clause": {
      "oneOf": [
        { "$ref": "#/$defs/processMatch" },
        { "$ref": "#/$defs/dnsMatch" },
        { "$ref": "#/$defs/flowMatch" },
        { "$ref": "#/$defs/browserExtensionMatch" },
        { "$ref": "#/$defs/saseComponentMatch" },
        { "$ref": "#/$defs/groupClause" }
      ]
    },
    "groupClause": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": {
          "type": "string",
          "enum": ["all_of", "any_of"]
        },
        "min_match": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32,
          "description": "For any_of: minimum number of child clauses that must match (defaults to 1)."
        },
        "of": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/clause"
          }
        }
      },
      "required": ["op", "of"]
    },
    "substringList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 128,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 512
      }
    },
    "processMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "process": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "case_insensitive": {
              "type": "boolean",
              "default": true
            },
            "executable_names_any": {
              "type": "array",
              "maxItems": 64,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256
              }
            },
            "executable_name_contains_any": {
              "$ref": "#/$defs/substringList"
            },
            "command_line_contains_any": {
              "$ref": "#/$defs/substringList"
            },
            "parent_executable_names_any": {
              "type": "array",
              "maxItems": 64,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 256
              }
            },
            "process_path_contains_any": {
              "$ref": "#/$defs/substringList"
            }
          },
          "minProperties": 1
        }
      },
      "required": ["process"]
    },
    "dnsMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dns": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "query_contains_any": {
              "$ref": "#/$defs/substringList"
            }
          },
          "required": ["query_contains_any"]
        }
      },
      "required": ["dns"]
    },
    "flowMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "flow": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "same_process_only": {
              "type": "boolean",
              "description": "If true, only flows attributed to the candidate process may satisfy this clause.",
              "default": true
            },
            "has_any_flow": {
              "type": "boolean",
              "description": "If true, any attributed flow observation satisfies this clause (subject to same_process_only)."
            },
            "remote_ports_any": {
              "type": "array",
              "maxItems": 32,
              "uniqueItems": true,
              "items": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              }
            },
            "remote_host_contains_any": {
              "$ref": "#/$defs/substringList"
            }
          },
          "minProperties": 1
        }
      },
      "required": ["flow"]
    },
    "browserExtensionMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "browser_extension": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "extension_id_contains_any": {
              "$ref": "#/$defs/substringList"
            },
            "name_contains_any": {
              "$ref": "#/$defs/substringList"
            },
            "permissions_contains_any": {
              "$ref": "#/$defs/substringList"
            }
          },
          "minProperties": 1
        }
      },
      "required": ["browser_extension"]
    },
    "saseComponentMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sase_component": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "display_name_contains_any": {
              "$ref": "#/$defs/substringList"
            },
            "vendor_contains_any": {
              "$ref": "#/$defs/substringList"
            },
            "collection_methods_any": {
              "type": "array",
              "maxItems": 32,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              }
            }
          },
          "minProperties": 1
        }
      },
      "required": ["sase_component"]
    }
  }
}
